# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
DB_URL=postgresql://user:pass@host:5432/dbname

# Redis (Upstash)
REDIS_URL=redis://default:token@host:6379

# LLM (OpenAI or compatible)
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4

# Frontend (Vercel/Netlify)
VITE_API_URL=https://your-backend-url.com
